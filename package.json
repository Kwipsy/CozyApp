{
    "scripts": {
        "dev": "concurrently \"npm --prefix frontend run dev\" \"dotnet run --project backend/src/CozyApp.Api\"",
        "db:start": "docker compose up -d",
        "db:stop": "docker compose down -v",
        "frontend": "cd frontend && npm run dev",
        "backend": "cd backend/src/CozyApp.Api && dotnet run"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
